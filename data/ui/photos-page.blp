using Gtk 4.0;
using Adw 1;

template $PhotosPage : Adw.NavigationPage {
  title: "Photos";

  child: Gtk.Box root_box {
    orientation: vertical;

    Adw.HeaderBar header_bar {
      show-end-title-buttons: true;
    }

    Adw.ViewSwitcherBar switcher_bar {
      stack: view_stack;
      reveal: true;
    }

    Adw.ViewStack view_stack {
      vexpand: true;
    }
  };
}