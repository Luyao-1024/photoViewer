using Gtk 4.0;
using Adw 1;

template $TrashPage : Adw.NavigationPage {
  title: "";

  child: Gtk.Box root_box {
    orientation: vertical;

    Adw.HeaderBar header_bar {
      show-end-title-buttons: true;
      css-classes: ["glass-header"];

      [end]
      Gtk.Button empty_btn {
        label: "";
        css-classes: ["destructive-action"];
      }
    }

    Adw.Banner trash_banner {
      title: "";
      revealed: true;
    }

    Gtk.ScrolledWindow scrolled {
      vexpand: true;

      child: Gtk.Viewport grid_viewport {
        scroll-to-focus: true;

        child: Gtk.Box grid_content {
          orientation: vertical;

          Gtk.FlowBox flow_box {
            homogeneous: true;
            selection-mode: multiple;
            column-spacing: 2;
            row-spacing: 2;
            margin-start: 12;
            margin-end: 12;
            margin-top: 12;
            margin-bottom: 12;
            max-children-per-line: 100;
            css-classes: ["thumb-grid"];
          }
        };
      };
    }

    Gtk.ActionBar action_bar {
      revealed: false;

      [start]
      Gtk.Button cancel_btn {
        label: "";
      }

      [end]
      Gtk.Button restore_btn {
        label: "";
        css-classes: ["suggested-action"];
      }

      [end]
      Gtk.Button delete_btn {
        label: "";
        css-classes: ["destructive-action"];
      }
    }
  };
}
